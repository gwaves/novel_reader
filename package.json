{
  "name": "novel_reader",
  "private": true,
  "version": "0.9.2",
  "description": "Offline-first novel reader with EPUB import, RAG search, knowledge graph extraction, and an Android companion app.",
  "license": "MIT",
  "author": "gwaves",
  "repository": {
    "type": "git",
    "url": "https://github.com/gwaves/novel_reader.git"
  },
  "keywords": [
    "novel-reader",
    "epub-reader",
    "rag",
    "knowledge-graph",
    "llm",
    "react",
    "typescript",
    "android"
  ],
  "type": "module",
  "scripts": {
    "api": "node --no-warnings scripts/local-db-server.mjs",
    "dev": "node scripts/dev.mjs",
    "gateway:dev": "npm --prefix gateway run dev",
    "gateway:build": "npm --prefix gateway run build",
    "gateway:start": "npm --prefix gateway run start",
    "gateway:test": "npm --prefix gateway run test",
    "gateway:security-smoke": "npm --prefix gateway run security-smoke",
    "gateway:ops-metrics-smoke": "npm --prefix gateway run ops-metrics-smoke --",
    "gateway:apk-metadata-smoke": "npm --prefix gateway run apk-metadata-smoke --",
    "gateway:rollback-release": "node gateway/scripts/rollback-release.mjs",
    "gateway:admin-ui:build": "npm --prefix gateway run admin-ui:build",
    "gateway:admin-ui:test": "npm --prefix gateway run admin-ui:test",
    "gateway:publish-audio": "node gateway/scripts/publish-audio.mjs",
    "gateway:publish-package": "node gateway/scripts/publish-package.mjs",
    "gateway:publish-android-apk": "node gateway/scripts/publish-android-apk.mjs",
    "production-pipeline": "node production-pipeline/src/cli.mjs",
    "production-pipeline:console": "node production-pipeline/src/service.mjs",
    "production-pipeline:console:dev": "node --watch production-pipeline/src/service.mjs",
    "production-pipeline:console:test": "node --test production-pipeline/test/service.test.mjs",
    "production-pipeline:service": "node production-pipeline/src/service.mjs",
    "production-pipeline:service:dev": "node --watch production-pipeline/src/service.mjs",
    "production-pipeline:service:test": "node --test production-pipeline/test/service.test.mjs",
    "production-pipeline:hermes-rescue": "node production-pipeline/scripts/hermes-rescue-worker.mjs",
    "production-pipeline:test": "node --test production-pipeline/test/*.test.mjs",
    "gateway-android:dev": "npm --prefix gateway-android-app run dev",
    "gateway-android:build": "npm --prefix gateway-android-app run build",
    "gateway-android:android:add": "npm --prefix gateway-android-app run android:add",
    "gateway-android:android:sync": "npm --prefix gateway-android-app run android:sync",
    "gateway-android:android:build": "npm --prefix gateway-android-app run android:build-fast",
    "vite:dev": "vite",
    "reader": "vite preview",
    "reader:build": "npm run build && npm run reader",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "local-db:test": "node --test tests/api/*.test.mjs",
    "test:e2e": "playwright test",
    "test:smoke": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@xyflow/react": "^12.11.0",
    "fastify": "^5.9.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
