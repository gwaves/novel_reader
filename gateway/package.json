{
  "name": "@novel-reader/gateway",
  "private": true,
  "version": "0.1.0",
  "description": "Cloud gateway service for Novel Reader mobile clients.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "admin-ui:build": "npm --prefix admin-ui run build",
    "admin-ui:test": "npm --prefix admin-ui run test",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "security-smoke": "bash scripts/security-smoke.sh",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "fastify": "^4.29.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}
