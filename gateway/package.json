{
  "name": "@novel-reader/gateway",
  "private": true,
  "version": "0.1.0",
  "description": "Cloud gateway service for Novel Reader mobile clients.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
