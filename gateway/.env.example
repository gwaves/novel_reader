GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=6180
GATEWAY_PUBLIC_BASE_URL=http://127.0.0.1:6180
GATEWAY_ENV=development
GATEWAY_LOG_LEVEL=info

# Development-only bearer token accepted by future protected routes.
GATEWAY_DEV_ACCESS_TOKEN=

# Required before production auth/token work.
GATEWAY_AUTH_TOKEN_SECRET=

# Comma-separated origins. Leave empty to disable browser CORS.
GATEWAY_CORS_ORIGINS=

GATEWAY_RATE_LIMIT_MAX=120
GATEWAY_RATE_LIMIT_WINDOW=1 minute

# Optional upstream services. Capabilities report unavailable until configured.
GATEWAY_AI_BASE_URL=
GATEWAY_AI_API_KEY=
GATEWAY_EMBEDDING_BASE_URL=
GATEWAY_EMBEDDING_API_KEY=

# Optional audio/object storage. Capabilities report unavailable until configured.
GATEWAY_OBJECT_STORAGE_ENDPOINT=
GATEWAY_OBJECT_STORAGE_BUCKET=
