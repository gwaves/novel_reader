GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=6180
GATEWAY_PUBLIC_BASE_URL=http://127.0.0.1:6180
GATEWAY_ENV=development
GATEWAY_LOG_LEVEL=info
GATEWAY_DATA_DIR=
GATEWAY_AUDIO_DIR=
GATEWAY_MAX_BODY_BYTES=52428800

# Development-only bearer token. Production does not use this as a fallback.
GATEWAY_DEV_ACCESS_TOKEN=
GATEWAY_ADMIN_ACCESS_TOKEN=
GATEWAY_MOBILE_ACCESS_TOKEN=

# Required before production auth/token work.
GATEWAY_AUTH_TOKEN_SECRET=

# Comma-separated origins. Leave empty to disable browser CORS. Production rejects wildcard "*".
GATEWAY_CORS_ORIGINS=

GATEWAY_RATE_LIMIT_MAX=120
GATEWAY_RATE_LIMIT_WINDOW=1 minute

# Optional upstream services. Capabilities report unavailable until configured.
GATEWAY_AI_BASE_URL=
GATEWAY_AI_API_KEY=
GATEWAY_AI_MODEL=
GATEWAY_EMBEDDING_BASE_URL=
GATEWAY_EMBEDDING_API_KEY=
GATEWAY_EMBEDDING_MODEL=
GATEWAY_UPSTREAM_TIMEOUT_MS=60000

# Optional audio/object storage. Capabilities report unavailable until configured.
GATEWAY_OBJECT_STORAGE_ENDPOINT=
GATEWAY_OBJECT_STORAGE_BUCKET=

# HTTPS profile only. On the 192.168.88.100 deployment this points at the
# Certbot config directory that contains live/novel.gwaves.net/fullchain.pem.
GATEWAY_LETSENCRYPT_CONFIG_DIR=/home/gwaves/letsencrypt/config
