{
  "name": "novel-reader-gateway-android-app",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "version:generate": "node scripts/generate-build-info.mjs",
    "predev": "npm run version:generate",
    "dev": "vite",
    "prebuild": "npm run version:generate",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "pretest": "npm run version:generate",
    "test": "vitest run src/*.test.ts",
    "preview": "vite preview",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:copy-assets": "npx cap copy android",
    "android:build-fast": "npm run build && npm run android:copy-assets && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/status-bar": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.0.0"
  }
}
